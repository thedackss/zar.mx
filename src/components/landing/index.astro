---
import styles from "./index.module.scss";

const name = "zar.mx";
const bio = "building things";

const links = [
    { label: "diego.zar.mx", href: "https://diego.zar.mx" },
    // { label: "dacks.dev", href: "https://dacks.dev" },
];

// Redes sociales
const socials = [
    { label: "github", href: "https://github.com/thedackss" },
    { label: "discord", href: "https://discord.com/users/524970765095796777" },
    { label: "x", href: "https://x.com/DiegoZar02" },
];
---

<main class={styles.landing}>
    <header>
        <h1>{name}</h1>
        <p>{bio}</p>
    </header>

    <nav>
        {
            links.map((link) => (
                <a href={link.href} target="_blank" rel="noopener noreferrer">
                    <span class={styles.label}>{link.label}</span>
                    <span class={styles.icon}>
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-3.5 w-3.5"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                            width="16"
                            height="16"
                        >
                            <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />{" "}
                            <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />{" "}
                        </svg>
                    </span>
                </a>
            ))
        }
    </nav>

    <footer>
        {
            socials.map((social) => (
                <a
                    class={styles.social}
                    href={social.href}
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    {social.label}
                </a>
            ))
        }
    </footer>
</main>
